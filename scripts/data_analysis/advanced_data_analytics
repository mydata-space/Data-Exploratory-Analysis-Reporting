-- ------------------------------------
-- Change over time trends analysis 
-- ------------------------------------

-- Analyze the performance of sales over time.
SELECT 
YEAR(order_date) years,
MONTH(order_date) months,
COUNT( DISTINCT customer_id) customer_number,
SUM(sales_amount) total_sales
FROM gold.fact_sales
WHERE order_date IS NOT NULL
GROUP BY YEAR(order_date), MONTH(order_date)
ORDER BY years, months 
-- The business sales experiend up and down trend between 2010 and 2013, then drastically decline in 2014.  

-- ------------------------------------
-- Cumulative analysis 
-- ------------------------------------
-- find the total monthly sales and the runing total
SELECT 
order_date,
total_sales,
SUM(total_sales) OVER(ORDER BY order_date) sales_running_total
FROM
(
	SELECT
	DATETRUNC(YEAR,order_date) order_date,
	SUM(sales_amount) total_sales
	FROM gold.fact_sales
	WHERE order_date IS NOT NULL
	GROUP BY DATETRUNC(YEAR,order_date)
) runing_total
ORDER BY order_date
-- the business grew over the period. 

-- ------------------------------------
-- Performance analysis 
-- ------------------------------------
-- Analyze the yearly performance of products category by comparing their sales to 
-- both the average sales performance of the product category and the previous year's sales 

WITH product_category_sales_performance_analysis AS
(
	SELECT 
	DATETRUNC(YEAR, s.order_date) order_date,
	p.category category,
	SUM(s.sales_amount) sales_amount 
	FROM gold.fact_sales s
	LEFT JOIN gold.dim_products p ON s.product_key = p.product_key
	WHERE order_date IS NOT NULL
	GROUP BY p.category , DATETRUNC(YEAR, s.order_date)
) 
SELECT 
order_date,
category,
sales_amount,
AVG(sales_amount) OVER(ORDER BY category) avg_sales, 
sales_amount - AVG(sales_amount) OVER(ORDER BY category) aveage_difference,
CASE 
	WHEN sales_amount - AVG(sales_amount) OVER(ORDER BY category) > 0 THEN 'above average'
	WHEN sales_amount - AVG(sales_amount) OVER(ORDER BY category) < 0 THEN 'below average'
	ELSE 'average'
END average_change,
LAG(sales_amount) OVER(PARTITION BY category ORDER BY order_date) py_category_sales,
sales_amount - LAG(sales_amount) OVER(PARTITION BY category ORDER BY order_date) diff_py_category_sales,
CASE 
	WHEN sales_amount - LAG(sales_amount) OVER(PARTITION BY category ORDER BY order_date) > 0 THEN 'increasing'
	WHEN sales_amount - LAG(sales_amount) OVER(PARTITION BY category ORDER BY order_date) < 0 THEN 'decreasing'
	ELSE 'no change'
END py_category_sales_change
FROM product_category_sales_performance_analysis 
ORDER BY category, order_date

-- ------------------------------------
-- Part to whole analysis 
-- ------------------------------------
-- which category contribute the most to the overall sales
WITH category_sales_contribution AS
(
	SELECT 
	p.category category,
	SUM(s.sales_amount) sales_amount 
	FROM gold.fact_sales s
	LEFT JOIN gold.dim_products p ON s.product_key = p.product_key
	GROUP BY p.category 
)
SELECT 
category,
sales_amount,
SUM(sales_amount) OVER(),
CONCAT(ROUND(CAST (sales_amount AS float) / SUM(sales_amount) OVER() * 100,2),'%') percent_of_total
FROM category_sales_contribution
ORDER BY percent_of_total DESC

-- ------------------------------------
-- Segmentation analysis 
-- ------------------------------------
-- segment products into cost range and count how many products fall into each segment. 
-- create ranges of products cost from cheap to most expensive. 
WITH product_segment AS
(
SELECT 
product_id,
product_name,
cost,
CASE 
	WHEN cost < 100 THEN 'below 100'
	WHEN cost BETWEEN 100 AND 500 THEN '100-500'
	WHEN cost BETWEEN 500 AND 1000 THEN '500-1000'
	ELSE 'above 1000'
END cost_range
FROM gold.dim_products
)
SELECT 
cost_range,
COUNT(product_id) total_products
FROM product_segment
GROUP BY cost_range
ORDER BY total_products DESC
 
/* Group customers into three segments based on their spending behavior:
	- VIP: Customers with at least 12 months of history and 
	  spending more than €5,000.
	- Regular: Customers with at least 12 months of history but spending €5,000 
	  or less.
	- New: Customers with a lifespan less than 12 months.
And find the total number of customers by each group
*/

WITH customer_spending AS
(
SELECT 
c.customer_id, 
SUM(s.sales_amount) total_spending,
MIN(s.order_date) first_order ,
MAX(s.order_date) last_order ,
DATEDIFF(MONTH,MIN(s.order_date),MAX(s.order_date)) life_span
FROM gold.fact_sales s
LEFT JOIN gold.dim_customers c ON s.customer_id = c.customer_id
GROUP BY c.customer_id
), customer_segmentation AS
(
SELECT 
customer_id,
total_spending,
life_span,
CASE 
	WHEN life_span >= 12 AND total_spending > 5000 THEN 'VIP customers'
	WHEN life_span >= 12 AND total_spending <= 5000 THEN 'Regular customers'
	ELSE 'New customers'
END customer_segment
FROM customer_spending
)
SELECT 
customer_segment,
COUNT(*) number_of_customers
FROM customer_segmentation
GROUP BY customer_segment


 












